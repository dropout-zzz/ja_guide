   <text:p text:style-name="P26"><text:span text:style-name="T16">A standing person spreading </text:span><text:span text:style-name="T17">his </text:span><text:span text:style-name="T16">arms and legs with an extra line added <text:s text:c="59"/>　　　　　　　</text:span><text:span text:style-name="T18">above</text:span><text:span text:style-name="T16">, </text:span><text:span text:style-name="T19">which </text:span><text:span text:style-name="T17">stand</text:span><text:span text:style-name="T20">s</text:span><text:span text:style-name="T17"> for “</text:span><text:span text:style-name="T21">a </text:span><text:span text:style-name="T17">high spot in the sky”.</text:span></text:p>
